{
  "name": "bun-chat-websocket",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "kill-port": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :3200') do taskkill /PID %a /F",
    "start": "kill-port 3200 && bun src/index.ts",
    "dev": "kill-port 3200 && bun --hot src/index.ts",
    "seed": "bun seed/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "kill-port": "^2.0.1",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "pg": "^8.20.0",
    "zod": "^3.22.4"
  }
}
